# `run` is the legacy fallback — Replit's "Project" workflow below is what
# the Run button actually triggers. Both point at bin/replit-start.sh so a
# Run/Restart pulls origin/main before booting (see that script's header).
run = "bash bin/replit-start.sh"
entrypoint = "server.js"
modules = ["nodejs-20"]

[nix]
channel = "stable-23_11"

[deployment]
run = ["sh", "-c", "npm start"]
deploymentTarget = "gce"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
# bin/replit-start.sh hard-resets to origin/main, then execs node server.js.
# Every Run/Restart wipes Replit's "Published your App" auto-commits and
# pulls Mac's latest pushed work in one click. See the script header.
args = "bash bin/replit-start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[userenv]

[userenv.shared]
ADMIN_PASSWORD = "Um112684!!"
